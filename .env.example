# Redis (default matches docker-compose.yml)
REDIS_URL=redis://127.0.0.1:6379

# OpenAI — required for embeddings, chat, and seeding handbook vectors
OPENAI_API_KEY=sk-...

# Optional overrides
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Cosine distance threshold for cache HIT (lower = stricter). Default 0.27 fits common demo rephrases
# (e.g. full-time vs new-hires PTO count). Vague wording like “annual vacation accrual” stays a miss.
SEMANTIC_CACHE_MAX_DISTANCE=0.27

# How many nearest cached queries to consider (closest under threshold wins). Default 10.
# SEMANTIC_CACHE_TOP_K=10
