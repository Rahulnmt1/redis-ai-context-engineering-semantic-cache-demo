# Redis (default matches docker-compose.yml)
REDIS_URL=redis://127.0.0.1:6379

# OpenAI — required for embeddings, chat, and seeding handbook vectors
OPENAI_API_KEY=sk-...

# Optional overrides
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Cosine distance threshold for semantic cache hits (lower = stricter). Tune during rehearsal.
SEMANTIC_CACHE_MAX_DISTANCE=0.22
